# ── WeatherAPI.com ────────────────────────────────────────────────────────────
# Get a free key at https://www.weatherapi.com/
WEATHER_API_KEY=your_api_key_here
WEATHER_API_BASE_URL=https://api.weatherapi.com/v1
WEATHER_QUERY=Cambodia          # city, country, or lat,lon e.g. "11.55,104.92"
WEATHER_AQI=no                  # yes / no
WEATHER_LANGUAGE=en
WEATHER_TIMEOUT_SECONDS=30

# ── File paths ────────────────────────────────────────────────────────────────
RAW_WEATHER_PATH=./data/raw/weather.json
PROCESSED_WEATHER_PATH=./data/processed/weather_cleaned_csv

# ── Database ──────────────────────────────────────────────────────────────────
# Local MySQL example:
DATABASE_URL=mysql+pymysql://root:yourpassword@127.0.0.1:3306/weather_etl
# Docker MySQL (used automatically inside docker-compose):
# DATABASE_URL=mysql+pymysql://weather:weather@mysql:3306/weather_etl
WEATHER_TABLE_NAME=weather_current
